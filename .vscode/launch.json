{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Django",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "program": "${workspaceFolder}/backend/manage.py",
            "args": [ "runserver", "8001" ],
            "cwd": "${workspaceFolder}/backend",
            "django": true,
            "justMyCode": false
        }
    ]
}